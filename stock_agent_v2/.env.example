# Stock Agent — 환경 변수 템플릿.
# 새 PC/GX10 셋업 시 이 파일을 .env 로 복사하고 값 채우세요.
# 실제 .env 는 git ignore + .dockerignore 둘 다 적용되어 절대 commit/image 에 안 들어감.

# ─── 텔레그램 ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_IDS=                  # 콤마 구분 — /명령 트리거 허용 사용자

# ─── KIS Open API ─────────────────────────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_PAPER_TRADING=0                    # 1=모의투자, 0=실전
# KIS_TOKEN_CACHE_DIR=                 # 미설정 시 Docker 컨테이너 내 /app/tokens 사용
                                       # Windows 직접 운영 시 Google Drive 공유 경로

# ─── Turso (libSQL) ──────────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── LLM ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AI_PRIMARY=claude                      # claude | gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_THINKING_BUDGET=1024

# ─── DART (한국 공시) ─────────────────────────────────────────────
DART_API_KEY=

# ─── 뉴스 (market_warning) ───────────────────────────────────────
SERPER_API_KEY=

# ─── Naver 검색 (옵션, Serper 폴백) ─────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── 웹 서비스 ───────────────────────────────────────────────────
WEB_SECRET_KEY=                        # 세션 쿠키 서명. 길고 랜덤한 문자열.
                                       # `openssl rand -base64 36` 또는 동등한 방법
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_ONLY=1                             # 1: 텔레그램 한 줄 알림만. 0: 종목별 본문 발송

# ─── 스케줄 시각 (KST, hh:mm) ────────────────────────────────────
MARKET_WARNING_TIME=07:25
MORNING_BRIEF_TIME=07:30
EVENING_ANALYZE_TIME=17:00
SIGNAL_SCAN_TIME=17:30

# ─── ETF 모멘텀 (momentum_etf 체이닝) ────────────────────────────
ETF_ENABLED=1                          # 0 = ETF 스크리닝 건너뜀 (momentum_etf 없는 호스트)
ETF_SCREENER_DIR=D:/momentum_etf       # Linux/GX10: /home/...
# ETF_SCREENER_PYTHON=                 # venv 파이썬 직접 지정 시
ETF_SCREEN_TIMEOUT_SEC=1800

# ─── ngrok (선택, docker-compose --profile ngrok 일 때만) ────────
NGROK_AUTHTOKEN=
NGROK_DOMAIN=unbiased-tight-jay.ngrok-free.app
